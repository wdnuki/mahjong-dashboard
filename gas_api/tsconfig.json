{
  "compilerOptions": {
    "target": "ES2019",
    "module": "none",
    "lib": ["ES2019"],
    "types": ["google-apps-script"],
    "strict": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "noImplicitAny": false,
    "skipLibCheck": true
