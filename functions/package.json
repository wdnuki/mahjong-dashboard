{
  "name": "mahjong-dashboard-functions",
  "version": "1.0.0",
  "description": "Cloud Functions API for Mahjong Dashboard",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --minify --platform=node --target=node20 --outfile=lib/index.js --external:@google-cloud/bigquery --external:firebase-admin --external:firebase-functions",
    "build:watch": "tsc --watch",
    "predeploy": "npm run build"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.0.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.3"
  },
  "private": true
}
